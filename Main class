namespace PRG182
{
    internal class Program
    {
        static double income = 0;
        static double expenses = 0;
        static Dictionary<string, List<double>> peopleIncome = new Dictionary<string, List<double>>();
        static Dictionary<string, List<double>> peopleExpense= new Dictionary<string, List<double>>();
        static void Main(string[] args)
        {
            bool running = true;
            while (running)
            {
                DisplayMenu();

                Console.Write("Enter a option you like to do: ");

                int option = int.Parse(Console.ReadLine());



                Console.Clear();
                switch (option)
                {
                    case 1:

                        Console.WriteLine("1. Income \n2. Expense");
                        Console.Write("Enter a option you like to do: ");
                        int option2 = int.Parse(Console.ReadLine());

                        switch (option2)
                        {
                            case 1:
                                    Console.Write("Enter your name: ");
                                    string name = Console.ReadLine();
                                    Console.Write("Enter the amount of income: ");
                                    double income = double.Parse(Console.ReadLine());

                                    RecordTransaction(name, income);
                                break;
                            case 2:
                               
                                {
                                    Console.Write("Enter your name: ");
                                    string name2 = Console.ReadLine();
                                    Console.Write("Enter the amount of income: ");
                                    double exspense = double.Parse(Console.ReadLine());

                                    AddExspence(name2, exspense);
                                }
                                break;
                        }
                        break;
                    case 2:
                        DisplaySummury();
                        break;
                    case 3:
                        void ViewCatagory();
                        break;
                    case 4:

                        break;
                    case 5:
                        running = false;
                        break;
                    default:
                        Console.WriteLine("Invalid option please try again!");
                        break;
                }

                Console.WriteLine();
            }


        }
        static void DisplayMenu()
        {
            Console.WriteLine("1. Record income or expense \n2. View summary \n3. View by catagory \n4. View by user \n5. Exit");
        }

        static void RecordTransaction(string name, double income)
        {
            if (!peopleIncome.ContainsKey(name))
            {
                peopleIncome[name] = new List<double>(); ;
            }
            peopleIncome[name].Add(income);
            Console.WriteLine("Congrats you succesfully added an income of " + income + " to your account!");
        }
        static void AddExpense(string name , double exspense)
        {
            if (!peopleExpense.ContainsKey(name))
            {
                peopleExpense[name] = new List<double>();
            }
            peopleExspence[name].Add(exspense);
            Console.WriteLine("Congrats you succesfully added an expense of " + expense + " to your account!");
        }
      

        static void DisplaySummury()
        {
            foreach (var person in peopleIncome)
            {
                string name = person.Key;

                double totalIncome = person.Value.Sum();

                double totalExspence =
                    peopleExspence.ContainsKey(name)
                    ? peopleExspence[name].Sum()
                    : 0;

                double balance = totalIncome - totalExpense;

                Console.WriteLine($"Name: {name}");
                Console.WriteLine($"Total Income: {totalIncome}");
                Console.WriteLine($"Total Exspence: {totalExpense}");
                Console.WriteLine($"Balance: {balance}");
                Console.WriteLine();
            }
        }

static void ViewCatagory()
{
    Console.WriteLine("\nView by Category \n --------------------------------------");

    Console.Write("Enter the Category you'd like to review: ");
    string chosenCategory = Console.ReadLine().Trim();

    Console.WriteLine("\n--- Results for Category: " + chosenCategory + "---");

    double totalIncomeInCategory = 0;
    double totalExpenseInCategory = 0;

    // Check Income - code doesn't store categories
    Console.WriteLine("\nIncome records under current category:");
    foreach (var person in peopleIncome)
    {
        double personTotal = 0;

        // Manual run trough list(array) using a for loop
        for (int i = 0; i < person.Value.Count; i++)
        {
            personTotal += person.Value[i];
        }

        Console.WriteLine(person.Key + ": R" + personTotal);
        totalIncomeInCategory += personTotal;
    }

    // Check Expenses
    Console.WriteLine("\nExpense records under this category:");
    foreach (var person in peopleExpense)
    {
        double personTotal = 0;

        // Manual run through using a for loop
        for (int i = 0; i < person.Value.Count; i++)
        {
            personTotal += person.Value[i];
        }

        Console.WriteLine(person.Key + ": R" + personTotal);
        totalExpenseInCategory += personTotal;
    }

    Console.WriteLine("\n-----------------------------------");
    Console.WriteLine("Total Income in " + chosenCategory + ": R" + totalIncomeInCategory);
    Console.WriteLine("Total Expense in " + chosenCategory + ": R" + totalExpenseInCategory);
    Console.WriteLine("Net Balance for " + chosenCategory + ": R" + totalIncomeInCategory - totalExpenseInCategory);
}

    }
}
