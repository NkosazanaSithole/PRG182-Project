                Console.WriteLine();
            }
        }

static void ViewCatagory()
{
    Console.WriteLine("\nView by Category \n --------------------------------------");

    Console.Write("Enter the Category you'd like to review: ");
    string chosenCategory = Console.ReadLine().Trim();

    Console.WriteLine("\n--- Results for Category: " + chosenCategory + "---");

    double totalIncomeInCategory = 0;
    double totalExpenseInCategory = 0;

    // Check Income - code doesn't store categories
    Console.WriteLine("\nIncome records under current category:");
