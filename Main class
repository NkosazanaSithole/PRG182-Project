    {
        double personTotal = 0;

        // Manual run trough list(array) using a for loop
        for (int i = 0; i < person.Value.Count; i++)
        {
            personTotal += person.Value[i];
        }

        Console.WriteLine(person.Key + ": R" + personTotal);
        totalIncomeInCategory += personTotal;
    }

    // Check Expenses
    Console.WriteLine("\nExpense records under this category:");
    foreach (var person in peopleExpense)
    {
        double personTotal = 0;

